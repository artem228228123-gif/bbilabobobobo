# ============================================
# AIDA — Премиальная доска объявлений
# Версия: 3.0 ULTRA
# Файл: .env.example
# Описание: Пример переменных окружения (скопируйте в .env и заполните)
# ============================================

# ============================================
# ОСНОВНЫЕ НАСТРОЙКИ
# ============================================

# Режим работы: development, production, test
NODE_ENV=development

# Порт сервера
PORT=3000

# URL клиентского приложения
CLIENT_URL=http://localhost:3000

# ============================================
# БАЗА ДАННЫХ (PostgreSQL)
# ============================================

# Хост базы данных
DB_HOST=localhost

# Порт базы данных
DB_PORT=5432

# Имя базы данных
DB_NAME=aida

# Пользователь базы данных
DB_USER=aida

# Пароль базы данных (обязательно измените!)
DB_PASSWORD=your_strong_password_here

# Использовать SSL для подключения к БД
DB_SSL=false

# Максимальное количество соединений в пуле
DB_POOL_MAX=20

# Таймаут бездействия соединения (мс)
DB_IDLE_TIMEOUT=30000

# Таймаут подключения (мс)
DB_CONNECTION_TIMEOUT=2000

# Таймаут выполнения запроса (мс)
DB_STATEMENT_TIMEOUT=30000

# Таймаут запроса (мс)
DB_QUERY_TIMEOUT=30000

# ============================================
# REDIS (КЕШ И ОЧЕРЕДИ)
# ============================================

# Хост Redis
REDIS_HOST=localhost

# Порт Redis
REDIS_PORT=6379

# Пароль Redis (если установлен)
REDIS_PASSWORD=

# Номер базы данных Redis
REDIS_DB=0

# Полный URL подключения к Redis
REDIS_URL=redis://localhost:6379

# ============================================
# JWT АУТЕНТИФИКАЦИЯ
# ============================================

# Секретный ключ для JWT (обязательно измените!)
JWT_SECRET=your_super_secret_jwt_key_change_me_please

# Срок действия токена
JWT_EXPIRES_IN=7d

# Срок действия refresh токена
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# БЕЗОПАСНОСТЬ
# ============================================

# Количество раундов для bcrypt
BCRYPT_ROUNDS=12

# Включить CSRF защиту
CSRF_ENABLED=true

# Окно для rate limiting (мс)
RATE_LIMIT_WINDOW_MS=900000

# Максимальное количество запросов
RATE_LIMIT_MAX_REQUESTS=100

# API ключ для администраторов
ADMIN_API_KEY=your_admin_api_key_here

# ============================================
# ЗАГРУЗКА ФАЙЛОВ
# ============================================

# Максимальный размер файла (байт)
UPLOAD_MAX_SIZE=10485760

# Максимальное количество файлов за раз
UPLOAD_MAX_FILES=10

# Разрешённые MIME типы
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,video/mp4

# Путь для сохранения загруженных файлов
UPLOAD_PATH=./uploads

# Качество сжатия изображений (1-100)
IMAGE_QUALITY=80

# ============================================
# EMAIL (SMTP)
# ============================================

# SMTP сервер
SMTP_HOST=smtp.gmail.com

# SMTP порт
SMTP_PORT=587

# SMTP пользователь
SMTP_USER=your_email@gmail.com

# SMTP пароль (для Gmail используйте пароль приложения)
SMTP_PASS=your_app_password_here

# Email отправителя
SMTP_FROM=noreply@aida.ru

# ============================================
# OAuth ПРОВАЙДЕРЫ
# ============================================

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Яндекс OAuth
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret

# VK OAuth
VK_CLIENT_ID=your_vk_client_id
VK_CLIENT_SECRET=your_vk_client_secret

# Telegram OAuth
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ============================================
# КАРТЫ
# ============================================

# Провайдер карт: openstreetmap, yandex
MAP_PROVIDER=openstreetmap

# API ключ Яндекс.Карт (опционально)
YANDEX_MAPS_API_KEY=your_yandex_maps_api_key

# ============================================
# AI И НЕЙРОСЕТИ
# ============================================

# Включить NSFW детекцию
NSFW_DETECTION=false

# Яндекс Cloud для Vision API
YANDEX_CLOUD_FOLDER_ID=your_yandex_cloud_folder_id
YANDEX_CLOUD_IAM_TOKEN=your_yandex_cloud_iam_token

# ============================================
# ПЛАТЕЖИ (ЮKassa)
# ============================================

# ID магазина в ЮKassa
YOOKASSA_SHOP_ID=your_yookassa_shop_id

# Секретный ключ ЮKassa
YOOKASSA_SECRET_KEY=your_yookassa_secret_key

# URL для возврата после оплаты
YOOKASSA_RETURN_URL=http://localhost:3000/payment/success

# ============================================
# SMS (SMS.ru)
# ============================================

# Провайдер SMS
SMS_PROVIDER=smsru

# API ключ SMS.ru
SMSRU_API_KEY=your_smsru_api_key

# Имя отправителя
SMS_SENDER=AIDA

# ============================================
# ОБЛАЧНОЕ ХРАНИЛИЩЕ (S3)
# ============================================

# Access key для S3
S3_ACCESS_KEY=your_s3_access_key

# Secret key для S3
S3_SECRET_KEY=your_s3_secret_key

# Имя бакета
S3_BUCKET=aida-uploads

# Endpoint S3
S3_ENDPOINT=https://s3.ru-msk.cloud.ru

# Регион S3
S3_REGION=ru-msk

# URL CDN
CDN_URL=https://cdn.aida.ru

# ============================================
# PUSH УВЕДОМЛЕНИЯ (VAPID)
# ============================================

# Публичный ключ VAPID
VAPID_PUBLIC_KEY=your_vapid_public_key

# Приватный ключ VAPID
VAPID_PRIVATE_KEY=your_vapid_private_key

# Email для VAPID
VAPID_SUBJECT=mailto:support@aida.ru

# ============================================
# КЛАСТЕРИЗАЦИЯ
# ============================================

# Включить кластеризацию (только для production)
CLUSTER_ENABLED=false

# ============================================
# МОНИТОРИНГ
# ============================================

# DSN для Sentry (отслеживание ошибок)
SENTRY_DSN=your_sentry_dsn

# API ключ UptimeRobot
UPTIMEROBOT_API_KEY=your_uptimerobot_api_key

# Включить мониторинг
MONITORING_ENABLED=false

# ============================================
# ЛОГИРОВАНИЕ
# ============================================

# Уровень логирования: error, warn, info, http, debug
LOG_LEVEL=debug

# Включить запись логов в файл
LOG_FILE_ENABLED=true

# Путь для сохранения логов
LOG_FILE_PATH=./logs

# Максимальное количество файлов логов
LOG_MAX_FILES=30

# Максимальный размер файла лога (MB)
LOG_MAX_SIZE_MB=10

# ============================================
# КЕШИРОВАНИЕ
# ============================================

# TTL для кеша категорий (секунды)
CACHE_CATEGORIES_TTL=3600

# TTL для кеша городов (секунды)
CACHE_CITIES_TTL=3600

# TTL для кеша популярных объявлений (секунды)
CACHE_POPULAR_TTL=600

# TTL для кеша ленты пользователя (секунды)
CACHE_USER_FEED_TTL=3600

# ============================================
# МОДУЛИ (ВКЛ/ВЫКЛ)
# ============================================

# ---------- Финансовый модуль ----------
FINANCE_MODULE_ENABLED=false
FINANCE_TEST_MODE=true
COMMISSION_PERCENT=0

# ---------- Доставка ----------
DELIVERY_MODULE_ENABLED=false
DELIVERY_VIRTUAL_MODE=true

# ---------- Бонусы ----------
BONUS_MODULE_ENABLED=true
DAILY_BONUS_AMOUNT=100
REFERRAL_BONUS_AMOUNT=50
STREAK_BONUS_PERCENT=10

# ---------- Лотерея ----------
LOTTERY_MODULE_ENABLED=true
LOTTERY_TICKET_PRICE=100
LOTTERY_PRIZE_POOL_PERCENT=70
LOTTERY_DRAW_DAY=0
LOTTERY_DRAW_HOUR=20

# ---------- Рефералы ----------
REFERRAL_MODULE_ENABLED=true
REFERRAL_REGISTRATION_BONUS=50
REFERRAL_SALE_BONUS=100

# ---------- Аукцион ----------
AUCTION_MODULE_ENABLED=true
AUCTION_MIN_STEP_PERCENT=5
AUCTION_DEFAULT_DURATION_DAYS=7

# ---------- TikTok-лента ----------
TIKTOK_MODULE_ENABLED=true
TIKTOK_FEED_SIZE=50
TIKTOK_CACHE_TTL=3600

# ---------- Карта ----------
MAP_MODULE_ENABLED=true
MAP_DEFAULT_ZOOM=10
MAP_MAX_MARKERS=500

# ---------- Чёрный список ----------
BLACKLIST_MODULE_ENABLED=true
AUTO_BLOCK_AFTER_REPORTS=3
AUTO_BLOCK_HOURS=24

# ============================================
# ВРЕМЕННЫЕ НАСТРОЙКИ
# ============================================

# Временная зона
TZ=Europe/Moscow

# ============================================
# ДЛЯ ТЕСТИРОВАНИЯ
# ============================================

# Тестовый режим
TEST_MODE=false

# Использовать моковые данные
USE_MOCKS=false