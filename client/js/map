// ============================================
// ЗАПУСК
// ============================================

document.addEventListener('DOMContentLoaded', () => {
    if (window.location.pathname.includes('map.html') || document.getElementById('map-container')) {
        addMapStyles();
        initMap();
        loadMapCategories();
        initPriceFilters();
    }
});