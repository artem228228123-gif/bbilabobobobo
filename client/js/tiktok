function setupKeyboardShortcuts() {
    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowUp') {
            // Скролл вверх
            tiktokContainer.scrollBy(0, -window.innerHeight);
        } else if (e.key === 'ArrowDown') {
            // Скролл вниз
            tiktokContainer.scrollBy(0, window.innerHeight);
        } else if (e.key === ' ' || e.key === 'Space') {
            e.preventDefault();
            const activeCard = document.querySelector(`.tiktok-card[data-index="${tiktokState.currentIndex}"]`);
            const video = activeCard?.querySelector('video');
            if (video) {
                if (video.paused) video.play();
                else video.pause();
            }
        }
    });
}

