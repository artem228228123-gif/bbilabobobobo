        'sold': 'Продано',
        'archived': 'В архиве',
        'rejected': 'Отклонено'
    };
    return statuses[status] || status;
}

function getListingStatusClass(status) {
    const classes = {
        'active': 'status-active',
        'pending': 'status-pending',
        'sold': 'status-sold',
        'archived': 'status-archived',
        'rejected': 'status-rejected'
    };
    return classes[status] || '';
}

async function exportStats() {
    if (!statsData) return;
    
    const csvContent = [
        ['Дата', 'Просмотры', 'Лайки', 'Новые объявления'],
        ...(statsData.views_history?.map((h, i) => [
            h.date,
            h.count,
            statsData.likes_history?.[i]?.count || 0,
            statsData.listings_history?.[i]?.count || 0
        ]) || [])
    ].map(row => row.join(';')).join('\n');
    
    const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = `stats_${new Date().toISOString().split('T')[0]}.csv`;
    link.click();
    URL.revokeObjectURL(link.href);
    
    showToast('Экспорт завершён', 'success');
}

