async function initNotificationsSettings() {
    try {
        const response = await fetch('/api/v1/notifications/settings', {
            headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
        });
        
        if (response.ok) {
            const settings = await response.json();
            renderNotificationsSettings(settings);
        }
    } catch (error) {
        console.error('Ошибка загрузки настроек:', error);
    }
}

function renderNotificationsSettings(settings) {
    const container = document.getElementById('profile-tab-content');
    if (!container || currentTab !== 'settings') return;
    
    container.innerHTML = `
        <div class="settings-section">
            <h3>Уведомления</h3>
            <div class="settings-item">
                <label>📧 Email уведомления</label>
                <label class="switch">
                    <input type="checkbox" id="notif-email" ${settings.email ? 'checked' : ''}>
                    <span class="slider"></span>
                </label>
            </div>
            <div class="settings-item">
                <label>🔔 Push-уведомления</label>
                <label class="switch">
                    <input type="checkbox" id="notif-push" ${settings.push ? 'checked' : ''}>
                    <span class="slider"></span>
                </label>
            </div>
            <div class="settings-item">
                <label>📱 Telegram уведомления</label>
                <label class="switch">
                    <input type="checkbox" id="notif-telegram" ${settings.telegram ? 'checked' : ''}>
                    <span class="slider"></span>
                </label>
            </div>
            <button class="btn-primary save-notif-settings">Сохранить</button>
        </div>
        
        <div class="settings-section">
            <h3>Безопасность</h3>
            <button class="btn-outline change-password-btn" id="change-password-btn">🔐 Сменить пароль</button>
            <button class="btn-outline logout-all-btn" id="logout-all-btn">🚪 Выйти из всех устройств</button>
            <button class="btn-danger delete-account-btn" id="delete-account-btn">⚠️ Удалить аккаунт</button>
        </div>
    `;
    
    // Сохранение настроек
    const saveBtn = container.querySelector('.save-notif-settings');
    saveBtn?.addEventListener('click', () => saveNotificationSettings());
    
    // Смена пароля
    document.getElementById('change-password-btn')?.addEventListener('click', openChangePasswordModal);
    
    // Выход из всех устройств
    document.getElementById('logout-all-btn')?.addEventListener('click', logoutAllDevices);
    
    // Удаление аккаунта
    document.getElementById('delete-account-btn')?.addEventListener('click', deleteAccount);
}

async function saveNotificationSettings() {
    const settings = {
        email: document.getElementById('notif-email')?.checked || false,
        push: document.getElementById('notif-push')?.checked || false,
        telegram: document.getElementById('notif-telegram')?.checked || false
    };
    
    try {
        const response = await fetch('/api/v1/notifications/settings', {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${localStorage.getItem('token')}`
            },
            body: JSON.stringify(settings)
        });
        
        if (response.ok) {
            showToast('Настройки сохранены', 'success');
        }
    } catch (error) {
        console.error('Ошибка:', error);
        showToast('Ошибка сохранения', 'error');
    }
}

function openChangePasswordModal() {
    const modal = document.getElementById('change-password-modal');
    if (!modal) return;
    modal.classList.add('active');
    
    const form = document.getElementById('change-password-form');
    form.onsubmit = async (e) => {
        e.preventDefault();
        await changePassword();
    };
}

async function changePassword() {
    const oldPassword = document.getElementById('old-password').value;
    const newPassword = document.getElementById('new-password').value;
    const confirmPassword = document.getElementById('confirm-password').value;
    
    if (newPassword !== confirmPassword) {
        showToast('Пароли не совпадают', 'error');
        return;
    }
    
    if (newPassword.length < 6) {
        showToast('Пароль должен быть минимум 6 символов', 'error');
        return;
    }
    
    try {
        const response = await fetch('/api/v1/auth/change-password', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${localStorage.getItem('token')}`
            },
            body: JSON.stringify({ old_password: oldPassword, new_password: newPassword })
        });
        
        if (response.ok) {
            showToast('Пароль изменён', 'success');
            document.getElementById('change-password-modal')?.classList.remove('active');
        } else {
            const data = await response.json();
            showToast(data.error || 'Ошибка', 'error');
        }
    } catch (error) {
        showToast('Ошибка соединения', 'error');
    }
}

async function logoutAllDevices() {
    if (!confirm('Вы уверены? Сессии на всех устройствах будут завершены.')) return;
    
    try {
        const response = await fetch('/api/v1/auth/logout-all', {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${localStorage.getItem('token')}`
            }
        });
        
        if (response.ok) {
            showToast('Вы вышли из всех устройств', 'success');
            setTimeout(() => logout(), 2000);
        }
    } catch (error) {
        showToast('Ошибка', 'error');
    }
}

async function deleteAccount() {
    if (!confirm('ВНИМАНИЕ! Это действие необратимо. Все ваши данные будут удалены. Продолжить?')) return;
    
    const password = prompt('Введите пароль для подтверждения:');
    if (!password) return;
    
    try {
        const response = await fetch('/api/v1/users/me', {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${localStorage.getItem('token')}`
            },
            body: JSON.stringify({ password })
        });
        
        if (response.ok) {
            showToast('Аккаунт удалён', 'success');
            logout();
        } else {
            const data = await response.json();
            showToast(data.error || 'Неверный пароль', 'error');
        }
    } catch (error) {
        showToast('Ошибка', 'error');
    }
}

// ============================================
// ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
// ============================================

function initProfileTabs() {
    const tabs = document.querySelectorAll('.tab-btn');
    tabs.forEach(tab => {
        tab.addEventListener('click', async () => {
            const tabName = tab.dataset.tab;
            currentTab = tabName;
            
            // Обновляем активный класс
            tabs.forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            
            // Загружаем контент вкладки
            await loadTabContent(tabName);
        });
    });
    
    // Загружаем начальную вкладку
    loadTabContent(currentTab);
}

async function loadTabContent(tabName) {
    const container = document.getElementById('profile-tab-content');
    if (!container) return;
    
    switch (tabName) {
        case 'listings':
            listingsPage = 1;
            hasMoreListings = true;
            userListings = [];
            await loadUserListings(false);
            break;
        case 'stats':
            renderStats();
            break;
        case 'settings':
            renderNotificationsSettings({});
            break;
        case 'bonus':
            loadBonusTab();
            break;
        case 'referral':
            loadReferralTab();
            break;
        case 'garage':
            loadGarageTab();
            break;
        case 'resume':
            loadResumeTab();
            break;
        default:
            container.innerHTML = '<div class="loading-content">Загрузка...</div>';
    }
}

