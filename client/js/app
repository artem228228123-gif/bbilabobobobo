window.AIDA = {
    // Состояние приложения
    state: {
        user: null,
        token: localStorage.getItem('token'),
        theme: localStorage.getItem('theme') || 'light',
        isOnline: navigator.onLine,
        socket: null,
        unreadCount: 0,
        notifications: []
    },
    
    // Конфигурация
    config: {
        apiUrl: window.location.origin + '/api/v1',
        wsUrl: window.location.origin.replace('http', 'ws'),
        appName: 'АЙДА',
        version: '3.0.0'
    },
    
    // Контейнеры для DOM элементов
    elements: {},
    
    // Таймеры
    timers: {}
};

// ============================================
// ИНИЦИАЛИЗАЦИЯ
// ============================================

document.addEventListener('DOMContentLoaded', async () => {
    console.log('🚀 AIDA v3.0 ULTRA загружен');
    
    // Инициализация темы
    initTheme();
    
    // Инициализация Service Worker (PWA)
    initServiceWorker();
    
    // Проверка авторизации
    await checkAuth();
    
    // Инициализация WebSocket
    initWebSocket();
    
    // Инициализация UI компонентов
    initUIComponents();
    
    // Инициализация глобальных обработчиков
    initGlobalHandlers();
    
    // Проверка онлайн статуса
    initOnlineStatus();
    
    // Загрузка уведомлений
    if (window.AIDA.state.user) {
        loadNotifications();
    }
    
    // Инициализация страницы
    initCurrentPage();
});

// ============================================
// ТЕМА (СВЕТЛАЯ/ТЁМНАЯ)
// ============================================

function initTheme() {
    const theme = window.AIDA.state.theme;
    document.documentElement.setAttribute('data-theme', theme);
    
    // Кнопка переключения темы
    const themeToggle = document.getElementById('theme-toggle');
    if (themeToggle) {
        themeToggle.addEventListener('click', toggleTheme);
        themeToggle.textContent = theme === 'dark' ? '☀️' : '🌙';
    }
}

function toggleTheme() {
    const currentTheme = window.AIDA.state.theme;
    const newTheme = currentTheme === 'light' ? 'dark' : 'light';
    
    window.AIDA.state.theme = newTheme;
    localStorage.setItem('theme', newTheme);
    document.documentElement.setAttribute('data-theme', newTheme);
    
    const themeToggle = document.getElementById('theme-toggle');
    if (themeToggle) {
        themeToggle.textContent = newTheme === 'dark' ? '☀️' : '🌙';
    }
    
    // Событие для других компонентов
    window.dispatchEvent(new CustomEvent('themeChanged', { detail: { theme: newTheme } }));
}

// ============================================
// PWA SERVICE WORKER
// ============================================

function initServiceWorker() {
    if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js')
            .then(registration => {
                console.log('✅ Service Worker зарегистрирован:', registration.scope);
            })
            .catch(error => {
                console.error('❌ Ошибка регистрации Service Worker:', error);
            });
    }
    
    // Отслеживание установки PWA
    window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        window.AIDA.deferredPrompt = e;
        
        // Показываем кнопку установки
        const installBtn = document.getElementById('install-app');
        if (installBtn) {
            installBtn.style.display = 'flex';
            installBtn.addEventListener('click', () => {
                window.AIDA.deferredPrompt.prompt();
                window.AIDA.deferredPrompt.userChoice.then((choiceResult) => {
                    if (choiceResult.outcome === 'accepted') {
                        console.log('✅ Пользователь установил PWA');
                    }
                    window.AIDA.deferredPrompt = null;
                    installBtn.style.display = 'none';
                });
            });
        }
    });
}

// ============================================
// АВТОРИЗАЦИЯ
// ============================================

async function checkAuth() {
    const token = window.AIDA.state.token;
    if (!token) return;
    
    try {
        const response = await fetch(`${window.AIDA.config.apiUrl}/auth/me`, {
            headers: {
                'Authorization': `Bearer ${token}`
            }
        });
        
        if (response.ok) {
            const data = await response.json();
            window.AIDA.state.user = data.user;
            
            // Обновляем UI для авторизованного пользователя
            updateUIForAuth();
        } else {
            // Токен недействителен
            logout();
        }
    } catch (error) {
        console.error('Ошибка проверки авторизации:', error);
    }
}

function updateUIForAuth() {
    const user = window.AIDA.state.user;
    if (!user) return;
    
    // Обновляем аватар
    const avatarElements = document.querySelectorAll('.user-avatar');
    avatarElements.forEach(el => {
        el.src = user.avatar || '/images/default-avatar.png';
        el.alt = user.name;
    });
    
    // Обновляем имя пользователя
    const nameElements = document.querySelectorAll('.user-name');
    nameElements.forEach(el => {
        el.textContent = user.name;
    });
    
    // Показываем/скрываем элементы для авторизованных
    document.querySelectorAll('.auth-required').forEach(el => {
        el.style.display = 'block';
    });
    document.querySelectorAll('.guest-only').forEach(el => {
        el.style.display = 'none';
    });
    
    // Обновляем баланс бонусов
    updateBonusBalance();
}

function updateBonusBalance() {
    const balanceElements = document.querySelectorAll('.bonus-balance');
    if (balanceElements.length && window.AIDA.state.user) {
        fetch(`${window.AIDA.config.apiUrl}/bonus/balance`, {
            headers: { 'Authorization': `Bearer ${window.AIDA.state.token}` }
        })
        .then(res => res.json())
        .then(data => {
            balanceElements.forEach(el => {
                el.textContent = data.balance.toLocaleString();
            });
        })
        .catch(console.error);
    }
}

async function login(email, password) {
    try {
        const response = await fetch(`${window.AIDA.config.apiUrl}/auth/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
        });
        
        if (!response.ok) {
            const error = await response.json();
            throw new Error(error.error || 'Ошибка входа');
        }
        
        const data = await response.json();
        window.AIDA.state.token = data.token;
        window.AIDA.state.user = data.user;
        localStorage.setItem('token', data.token);
        
        // Инициализируем WebSocket
        initWebSocket();
        
        // Перезагружаем страницу
        window.location.href = '/';
        
    } catch (error) {
        showToast(error.message, 'error');
    }
}

function logout() {
    window.AIDA.state.token = null;
    window.AIDA.state.user = null;
    localStorage.removeItem('token');
    
    if (window.AIDA.state.socket) {
        window.AIDA.state.socket.disconnect();
        window.AIDA.state.socket = null;
    }
    
    window.location.href = '/login.html';
}

// ============================================
// WEBSOCKET
// ============================================

function initWebSocket() {
    if (!window.AIDA.state.token) return;
    
    const socket = io(window.AIDA.config.wsUrl, {
        auth: { token: window.AIDA.state.token },
        transports: ['websocket']
    });
    
    socket.on('connect', () => {
        console.log('✅ WebSocket подключён');
        window.AIDA.state.socket = socket;
    });
    
    socket.on('disconnect', () => {
        console.log('❌ WebSocket отключён');
    });
    
    socket.on('new_message', (data) => {
        handleNewMessage(data);
    });
    
    socket.on('new_message_notification', (data) => {
        showToast(`Новое сообщение от ${data.senderName}`, 'info');
        updateUnreadCount();
    });
    
    socket.on('user_status', (data) => {
        updateUserStatus(data.userId, data.status);
    });
    
    socket.on('unread_count', (data) => {
        window.AIDA.state.unreadCount = data.count;
        updateUnreadBadge();
    });
    
    return socket;
}

function updateUnreadCount() {
    if (window.AIDA.state.socket) {
        window.AIDA.state.socket.emit('get_unread_count');
    }
}

function updateUnreadBadge() {
    const badge = document.querySelector('.unread-badge');
    const count = window.AIDA.state.unreadCount;
    
    if (badge) {
        if (count > 0) {
            badge.textContent = count > 99 ? '99+' : count;
            badge.style.display = 'flex';
        } else {
            badge.style.display = 'none';
        }
    }
}

// ============================================
// УВЕДОМЛЕНИЯ
// ============================================

async function loadNotifications() {
    try {
        const response = await fetch(`${window.AIDA.config.apiUrl}/notifications`, {
            headers: { 'Authorization': `Bearer ${window.AIDA.state.token}` }
        });
        
        if (response.ok) {
            const data = await response.json();
            window.AIDA.state.notifications = data.notifications;
            renderNotifications();
        }
    } catch (error) {
        console.error('Ошибка загрузки уведомлений:', error);
    }
}

function renderNotifications() {
    const container = document.getElementById('notifications-list');
    if (!container) return;
    
    const notifications = window.AIDA.state.notifications;
    
    if (notifications.length === 0) {
        container.innerHTML = '<div class="notifications-empty">Нет уведомлений</div>';
        return;
    }
    
    container.innerHTML = notifications.map(notif => `
        <div class="notification-item ${notif.is_read ? 'read' : 'unread'}" data-id="${notif.id}">
            <div class="notification-icon">${getNotificationIcon(notif.type)}</div>
            <div class="notification-content">
                <div class="notification-title">${escapeHtml(notif.title)}</div>
                <div class="notification-message">${escapeHtml(notif.message)}</div>
                <div class="notification-time">${formatTime(notif.created_at)}</div>
            </div>
        </div>
    `).join('');
}

function getNotificationIcon(type) {
    const icons = {
        message: '💬',
        like: '❤️',
        sale: '💰',
        system: '🔔',
        review: '⭐',
        lottery: '🎰'
    };
    return icons[type] || '📢';
}

