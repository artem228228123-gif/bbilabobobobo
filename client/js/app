function initGlobalHandlers() {
    // Клик по карточке объявления
    document.addEventListener('click', (e) => {
        const card = e.target.closest('.listing-card');
        if (card && card.dataset.id) {
            window.location.href = `/listing.html?id=${card.dataset.id}`;
        }
        
        const likeBtn = e.target.closest('.like-btn');
        if (likeBtn) {
            e.preventDefault();
            handleLike(likeBtn);
        }
        
        const chatBtn = e.target.closest('.chat-btn');
        if (chatBtn && chatBtn.dataset.userId) {
            e.preventDefault();
            startChat(chatBtn.dataset.userId, chatBtn.dataset.listingId);
        }
    });
}

async function handleLike(btn) {
    const listingId = btn.dataset.id;
    const isLiked = btn.classList.contains('liked');
    
    try {
        const response = await fetch(`${window.AIDA.config.apiUrl}/listings/${listingId}/like`, {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${window.AIDA.state.token}`
            }
        });
        
        if (response.ok) {
            const data = await response.json();
            btn.classList.toggle('liked', data.liked);
            
            const countSpan = btn.querySelector('.like-count');
            if (countSpan) countSpan.textContent = data.likesCount;
            
            if (data.liked) {
                animateLike(btn);
            }
        } else if (response.status === 401) {
            window.location.href = '/login.html';
        }
    } catch (error) {
        console.error('Ошибка лайка:', error);
    }
}

function animateLike(btn) {
    const heart = document.createElement('div');
    heart.className = 'floating-heart';
    heart.innerHTML = '❤️';
    heart.style.left = `${btn.getBoundingClientRect().left}px`;
    heart.style.top = `${btn.getBoundingClientRect().top}px`;
    document.body.appendChild(heart);
    setTimeout(() => heart.remove(), 1000);
}

async function startChat(userId, listingId) {
    try {
        const response = await fetch(`${window.AIDA.config.apiUrl}/chats`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${window.AIDA.state.token}`
            },
            body: JSON.stringify({ seller_id: userId, listing_id: listingId })
        });
        
        if (response.ok) {
            const data = await response.json();
            window.location.href = `/chats.html?chat=${data.chat.id}`;
        } else if (response.status === 401) {
            window.location.href = '/login.html';
        } else {
            const error = await response.json();
            showToast(error.error, 'error');
        }
    } catch (error) {
        showToast('Ошибка создания чата', 'error');
    }
}

