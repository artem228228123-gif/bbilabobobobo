// ============================================
// ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
// ============================================

function formatFileSize(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
}

function updateUploadProgress(previewId, percent, status = 'uploading') {
    const preview = document.getElementById(previewId);
    if (!preview) return;
    
    const progressBar = preview.querySelector('.preview-progress');
    const statusEl = preview.querySelector('.preview-status');
    
    if (progressBar) {
        progressBar.style.width = `${percent}%`;
    }
    
    if (statusEl) {
        if (status === 'uploading') {
            statusEl.innerHTML = `📤 Загрузка ${Math.round(percent)}%`;
            statusEl.className = 'preview-status uploading';
        } else if (status === 'success') {
            statusEl.innerHTML = '✅ Готово';
            statusEl.className = 'preview-status success';
        } else if (status === 'error') {
            statusEl.innerHTML = '❌ Ошибка';
            statusEl.className = 'preview-status error';
        }
    }
}

