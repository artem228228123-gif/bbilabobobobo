function renderLogsTable(data) {
    const container = document.getElementById('admin-content');
    if (!container) return;
    
    container.innerHTML = `
        <div class="admin-table-header">
            <h3>Логи ошибок</h3>
            <select id="log-level-filter" class="filter-select">
                <option value="">Все уровни</option>
                <option value="error">Error</option>
                <option value="warning">Warning</option>
                <option value="info">Info</option>
            </select>
        </div>
        <div class="table-responsive">
            <table class="admin-table logs-table">
                <thead>
                    <tr><th>Время</th><th>Уровень</th><th>Сообщение</th><th>IP</th><th>Пользователь</th></tr>
                </thead>
                <tbody>
                    ${(data.logs || []).map(log => `
                        <tr class="log-${log.level}">
                            <td>${new Date(log.created_at).toLocaleString()}</td>
                            <td><span class="log-level ${log.level}">${log.level}</span></td>
                            <td>${escapeHtml(log.message)}</td>
                            <td>${log.ip || '-'}</td>
                            <td>${log.user_id || '-'}</td>
                        </tr>
                    `).join('')}
                </tbody>
            </table>
        </div>
    `;
    
    document.getElementById('log-level-filter')?.addEventListener('change', filterLogs);
}

function filterLogs() {
    const level = document.getElementById('log-level-filter')?.value || '';
    const rows = document.querySelectorAll('.logs-table tbody tr');
    
    rows.forEach(row => {
        const rowLevel = row.querySelector('.log-level')?.textContent || '';
        row.style.display = (!level || rowLevel === level) ? '' : 'none';
    });
}

