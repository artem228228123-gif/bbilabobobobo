async function loadCharts() {
    if (typeof Chart === 'undefined') {
        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/chart.js';
        script.onload = () => createAdminCharts();
        document.head.appendChild(script);
    } else {
        createAdminCharts();
    }
}

async function createAdminCharts() {
    try {
        const response = await fetch('/api/v1/admin/dashboard/charts?period=week', {
            headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
        });
        
        if (response.ok) {
            const data = await response.json();
            
            const usersCtx = document.getElementById('users-chart')?.getContext('2d');
            const listingsCtx = document.getElementById('listings-chart')?.getContext('2d');
            
            if (usersCtx && data.charts?.users) {
                new Chart(usersCtx, {
                    type: 'line',
                    data: {
                        labels: data.charts.users.map(u => u.date),
                        datasets: [{
                            label: 'Новые пользователи',
                            data: data.charts.users.map(u => u.count),
                            borderColor: '#10b981',
                            backgroundColor: 'rgba(16, 185, 129, 0.1)',
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            }
            
            if (listingsCtx && data.charts?.listings) {
                new Chart(listingsCtx, {
                    type: 'bar',
                    data: {
                        labels: data.charts.listings.map(l => l.date),
                        datasets: [{
                            label: 'Новые объявления',
                            data: data.charts.listings.map(l => l.count),
                            backgroundColor: '#3b82f6',
                            borderRadius: 8
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            }
        }
    } catch (error) {
        console.error('Ошибка загрузки графиков:', error);
    }
}

