        btn.addEventListener('click', () => resolveComplaint(btn.dataset.id, 'ignore'));
    });
    
    document.querySelectorAll('.delete-listing-complaint').forEach(btn => {
        btn.addEventListener('click', () => resolveComplaint(btn.dataset.id, 'delete_listing', btn.dataset.listingId));
    });
    
    document.querySelectorAll('.block-user-complaint').forEach(btn => {
        btn.addEventListener('click', () => resolveComplaint(btn.dataset.id, 'block_user', null, btn.dataset.userId));
    });
}

async function resolveComplaint(complaintId, action, listingId = null, userId = null) {
    try {
        const response = await fetch(`/api/v1/admin/complaints/${complaintId}/resolve`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${localStorage.getItem('token')}`
            },
            body: JSON.stringify({ action, comment: 'Решено администратором' })
        });
        
        if (response.ok) {
            showToast('Жалоба обработана', 'success');
            loadComplaints();
            if (action === 'delete_listing' && listingId) loadModeration();
            if (action === 'block_user' && userId) loadUsers();
        } else {
            showToast('Ошибка', 'error');
        }
    } catch (error) {
        showToast('Ошибка соединения', 'error');
    }
}

