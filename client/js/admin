    document.getElementById('user-search')?.addEventListener('input', filterUsers);
    document.getElementById('user-role-filter')?.addEventListener('change', filterUsers);
    document.getElementById('user-status-filter')?.addEventListener('change', filterUsers);
    
    // Пагинация
    document.querySelector('.prev-page')?.addEventListener('click', () => loadUsers(data.pagination.page - 1));
    document.querySelector('.next-page')?.addEventListener('click', () => loadUsers(data.pagination.page + 1));
    
