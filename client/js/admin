async function approveListing(listingId) {
    try {
        const response = await fetch(`/api/v1/admin/listings/${listingId}/approve`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${localStorage.getItem('token')}`
            }
        });
        
        if (response.ok) {
            showToast('Объявление одобрено', 'success');
            loadModeration();
        } else {
            showToast('Ошибка', 'error');
        }
    } catch (error) {
        showToast('Ошибка соединения', 'error');
    }
}

async function rejectListing(listingId) {
    const reason = prompt('Укажите причину отклонения:');
    if (!reason) return;
    
    try {
        const response = await fetch(`/api/v1/admin/listings/${listingId}/reject`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${localStorage.getItem('token')}`
            },
            body: JSON.stringify({ reason })
        });
        
        if (response.ok) {
            showToast('Объявление отклонено', 'success');
            loadModeration();
        } else {
            showToast('Ошибка', 'error');
        }
    } catch (error) {
        showToast('Ошибка соединения', 'error');
    }
}

