let currentListingsPage = 1;
let isLoadingListings = false;
let hasMoreListings = true;
let currentFilters = {};

// ============================================
// ЗАГРУЗКА ОБЪЯВЛЕНИЙ
// ============================================

async function loadListings(filters = {}, append = false) {
    if (isLoadingListings) return;
    
    isLoadingListings = true;
    
    const container = document.getElementById('listings-container');
    const skeleton = document.getElementById('listings-skeleton');
    
    if (!append && skeleton) skeleton.style.display = 'block';
    
    try {
        const params = new URLSearchParams({
            limit: 20,
            page: append ? currentListingsPage : 1,
            ...filters
        });
        
        const response = await fetch(`/api/v1/listings?${params}`);
        const data = await response.json();
        
        if (response.ok) {
            if (append) {
                renderListings(data.listings, true);
                currentListingsPage++;
                hasMoreListings = data.hasMore;
            } else {
                renderListings(data.listings, false);
                currentListingsPage = 2;
                hasMoreListings = data.hasMore;
            }
        } else {
            showToast(data.error || 'Ошибка загрузки объявлений', 'error');
        }
    } catch (error) {
        console.error('Ошибка загрузки объявлений:', error);
        showToast('Ошибка соединения с сервером', 'error');
    } finally {
        isLoadingListings = false;
        if (skeleton) skeleton.style.display = 'none';
    }
}

function renderListings(listings, append = false) {
    const container = document.getElementById('listings-container');
    if (!container) return;
    
    if (!append) container.innerHTML = '';
    
    if (!listings || listings.length === 0) {
        if (!append) {
            container.innerHTML = `
                <div class="empty-state">
                    <div class="empty-icon">📭</div>
                    <h3>Объявлений не найдено</h3>
                    <p>Попробуйте изменить параметры поиска</p>
                    <button class="btn-primary" onclick="resetFilters()">Сбросить фильтры</button>
                </div>
            `;
        }
        return;
    }
    
    listings.forEach(listing => {
        const card = createListingCard(listing);
        container.appendChild(card);
    });
}

function createListingCard(listing) {
    const card = document.createElement('div');
    card.className = 'listing-card';
    card.dataset.id = listing.id;
    
    const firstPhoto = listing.photos?.[0] || '/images/placeholder.jpg';
    const priceFormatted = formatPrice(listing.price);
    const timeAgo = formatTime(listing.created_at);
    
    card.innerHTML = `
        <div class="card-image">
            <img data-src="${firstPhoto}" alt="${escapeHtml(listing.title)}" loading="lazy">
            <button class="like-btn ${listing.isFavorite ? 'liked' : ''}" data-id="${listing.id}">
                <span class="like-icon">❤️</span>
                <span class="like-count">${formatNumber(listing.likes || 0)}</span>
            </button>
        </div>
        <div class="card-content">
            <div class="card-price">${priceFormatted}</div>
            <div class="card-title">${escapeHtml(listing.title)}</div>
            <div class="card-meta">
                <span class="card-location">📍 ${escapeHtml(listing.city || 'Не указан')}</span>
                <span class="card-time">🕒 ${timeAgo}</span>
            </div>
            <div class="card-seller">
                <img class="seller-avatar" src="${listing.seller_avatar || '/images/default-avatar.png'}" alt="${escapeHtml(listing.seller_name)}">
                <span class="seller-name">${escapeHtml(listing.seller_name)}</span>
                <span class="seller-rating">⭐ ${listing.seller_rating || 0}</span>
            </div>
        </div>
    `;
    
    // Обработчик лайка
    const likeBtn = card.querySelector('.like-btn');
    if (likeBtn) {
        likeBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            handleLike(likeBtn);
        });
    }
    
    // Клик по карточке
    card.addEventListener('click', () => {
        window.location.href = `/listing.html?id=${listing.id}`;
    });
    
    // Ленивая загрузка изображений
    const img = card.querySelector('img');
    if (img && img.dataset.src) {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    img.src = img.dataset.src;
                    img.removeAttribute('data-src');
                    observer.unobserve(img);
                }
            });
        });
        observer.observe(img);
    }
    
    return card;
}

