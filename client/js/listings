                    <div class="seller-name">${escapeHtml(listing.seller?.name)}</div>
                    <div class="seller-rating">${sellerRating}</div>
                    <div class="seller-stats">
                        <div>📦 ${formatNumber(listing.seller?.stats?.listingsCount || 0)} объявлений</div>
