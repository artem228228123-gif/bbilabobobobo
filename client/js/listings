                <h1 class="listing-title">${escapeHtml(listing.title)}</h1>
                <div class="listing-meta">
                    <span class="listing-views">👁️ ${formatNumber(listing.views || 0)}</span>
                    <span class="listing-likes">❤️ ${formatNumber(listing.likes || 0)}</span>
                    <span class="listing-date">📅 ${timeAgo}</span>
                </div>
                <div class="listing-location">
                    📍 ${escapeHtml(listing.city || 'Не указан')}
