async function markAsSold(listingId) {
    if (!confirm('Отметить объявление как проданное?')) return;
    
    try {
        const response = await fetch(`/api/v1/listings/${listingId}/sold`, {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${localStorage.getItem('token')}`
            }
        });
        
        if (response.ok) {
            showToast('Объявление отмечено как проданное! +50 бонусов', 'success');
            location.reload();
        } else {
            const data = await response.json();
            showToast(data.error || 'Ошибка', 'error');
        }
    } catch (error) {
        console.error('Ошибка:', error);
        showToast('Ошибка соединения с сервером', 'error');
    }
}

