function renderPhotoGallery(photos) {
    if (!photos || photos.length === 0) {
        return `
            <div class="gallery-main">
                <img src="/images/placeholder-large.jpg" alt="Нет фото">
            </div>
        `;
    }
    
    const mainPhoto = photos[0];
    const thumbnails = photos.slice(1, 5);
    
    return `
        <div class="gallery-main">
            <img id="gallery-main-img" src="${mainPhoto}" alt="Фото">
        </div>
        ${thumbnails.length > 0 ? `
            <div class="gallery-thumbnails">
                ${thumbnails.map(photo => `
                    <div class="gallery-thumb" data-src="${photo}">
                        <img src="${photo}" alt="Миниатюра">
                    </div>
                `).join('')}
            </div>
        ` : ''}
    `;
}

function initPhotoGallery() {
    const thumbs = document.querySelectorAll('.gallery-thumb');
    const mainImg = document.getElementById('gallery-main-img');
    
    thumbs.forEach(thumb => {
        thumb.addEventListener('click', () => {
            const src = thumb.dataset.src;
            if (mainImg && src) {
                mainImg.src = src;
            }
        });
    });
}

function renderStars(rating) {
    const fullStars = Math.floor(rating);
    const halfStar = rating % 1 >= 0.5;
    let stars = '';
    for (let i = 0; i < fullStars; i++) stars += '★';
    if (halfStar) stars += '½';
    for (let i = stars.length; i < 5; i++) stars += '☆';
    return stars;
}

function renderSpecs(specs) {
    if (!specs || Object.keys(specs).length === 0) return '';
    
    return `
        <div class="listing-specs">
            <h3>Характеристики</h3>
            <div class="specs-grid">
                ${Object.entries(specs).map(([key, value]) => `
                    <div class="spec-item">
                        <span class="spec-key">${escapeHtml(key)}</span>
                        <span class="spec-value">${escapeHtml(value)}</span>
                    </div>
                `).join('')}
            </div>
        </div>
    `;
}

async function loadSimilarListings(listingId) {
    try {
        const response = await fetch(`/api/v1/listings/similar/${listingId}?limit=6`);
        const data = await response.json();
        
        const container = document.getElementById('similar-listings');
        if (container && data.listings && data.listings.length > 0) {
            container.innerHTML = data.listings.map(listing => createSimilarCard(listing)).join('');
        } else if (container) {
            container.innerHTML = '<p class="no-similar">Похожих объявлений не найдено</p>';
        }
    } catch (error) {
        console.error('Ошибка загрузки похожих объявлений:', error);
    }
}

function createSimilarCard(listing) {
    const priceFormatted = formatPrice(listing.price);
    const firstPhoto = listing.photos?.[0] || '/images/placeholder.jpg';
    
    return `
        <div class="similar-card" onclick="location.href='/listing.html?id=${listing.id}'">
            <img src="${firstPhoto}" alt="${escapeHtml(listing.title)}" loading="lazy">
            <div class="similar-price">${priceFormatted}</div>
            <div class="similar-title">${escapeHtml(listing.title)}</div>
        </div>
    `;
}

// ============================================
// СОЗДАНИЕ ОБЪЯВЛЕНИЯ
// ============================================

let uploadedPhotos = [];
let photoPreviews = [];

async function createListing(event) {
    event.preventDefault();
    
    const form = event.target;
    const formData = new FormData(form);
    
    // Добавляем фото
    uploadedPhotos.forEach(photo => {
        formData.append('photos', photo.file);
    });
    
    const submitBtn = form.querySelector('[type="submit"]');
    const originalText = submitBtn?.textContent;
    if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Публикация...';
    }
    
    try {
        const response = await fetch('/api/v1/listings', {
            method: 'POST',
            headers: {
                'Authorization': `Bearer ${localStorage.getItem('token')}`
            },
            body: formData
        });
        
        const data = await response.json();
        
        if (response.ok) {
            showToast('Объявление успешно создано!', 'success');
            setTimeout(() => {
                window.location.href = `/listing.html?id=${data.listing.id}`;
            }, 1500);
        } else {
            showToast(data.error || 'Ошибка создания объявления', 'error');
        }
    } catch (error) {
        console.error('Ошибка создания:', error);
        showToast('Ошибка соединения с сервером', 'error');
    } finally {
        if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
        }
    }
}

function initImageUpload() {
    const dropzone = document.getElementById('dropzone');
    const fileInput = document.getElementById('photos');
    const previewContainer = document.getElementById('photo-preview');
    
    if (!dropzone) return;
    
    // Клик для выбора файлов
    dropzone.addEventListener('click', () => fileInput?.click());
    
    // Drag & Drop
    dropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropzone.classList.add('dragover');
    });
    
    dropzone.addEventListener('dragleave', () => {
        dropzone.classList.remove('dragover');
    });
    
    dropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropzone.classList.remove('dragover');
        const files = Array.from(e.dataTransfer.files);
        handleFiles(files);
    });
    
    // Выбор файлов
    if (fileInput) {
        fileInput.addEventListener('change', (e) => {
            const files = Array.from(e.target.files);
            handleFiles(files);
        });
    }
    
    // Категории
    loadCategoriesSelect();
}

function handleFiles(files) {
    const imageFiles = files.filter(f => f.type.startsWith('image/'));
    
    if (uploadedPhotos.length + imageFiles.length > 10) {
        showToast('Максимум 10 фото', 'error');
        return;
    }
    
    imageFiles.forEach(file => {
        if (file.size > 10 * 1024 * 1024) {
            showToast(`Файл ${file.name} превышает 10MB`, 'error');
            return;
        }
        
        const reader = new FileReader();
        reader.onload = (e) => {
            photoPreviews.push(e.target.result);
            uploadedPhotos.push({ file, preview: e.target.result });
            renderPhotoPreviews();
        };
        reader.readAsDataURL(file);
    });
}

function renderPhotoPreviews() {
    const container = document.getElementById('photo-preview');
    if (!container) return;
    
    if (photoPreviews.length === 0) {
        container.innerHTML = '<div class="empty-photos">📸 Нажмите или перетащите фото</div>';
        return;
    }
    
    container.innerHTML = photoPreviews.map((preview, index) => `
        <div class="photo-preview-item">
            <img src="${preview}" alt="Фото ${index + 1}">
            <button type="button" class="remove-photo" data-index="${index}">✕</button>
        </div>
    `).join('');
    
    // Обработчики удаления
    document.querySelectorAll('.remove-photo').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const index = parseInt(btn.dataset.index);
            photoPreviews.splice(index, 1);
            uploadedPhotos.splice(index, 1);
            renderPhotoPreviews();
        });
    });
}

async function loadCategoriesSelect() {
    const select = document.getElementById('category_id');
    if (!select) return;
    
    try {
        const response = await fetch('/api/v1/categories');
        const data = await response.json();
        
        if (response.ok) {
            select.innerHTML = '<option value="">Выберите категорию</option>' + 
                data.categories.map(cat => `
                    <option value="${cat.id}">${escapeHtml(cat.name)}</option>
                `).join('');
        }
    } catch (error) {
        console.error('Ошибка загрузки категорий:', error);
    }
}

