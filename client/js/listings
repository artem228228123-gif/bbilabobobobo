async function loadListing(listingId) {
    const container = document.getElementById('listing-detail');
    const skeleton = document.getElementById('listing-skeleton');
    
    if (skeleton) skeleton.style.display = 'block';
    
    try {
        const response = await fetch(`/api/v1/listings/${listingId}`);
        const data = await response.json();
        
        if (response.ok) {
            renderListingDetail(data.listing);
            document.title = `${data.listing.title} — АЙДА`;
        } else {
            showToast(data.error || 'Объявление не найдено', 'error');
            setTimeout(() => {
                window.location.href = '/';
            }, 2000);
        }
    } catch (error) {
        console.error('Ошибка загрузки объявления:', error);
        showToast('Ошибка соединения с сервером', 'error');
    } finally {
        if (skeleton) skeleton.style.display = 'none';
    }
}

